{
  "fido2": {
    "serverDomain": "localhost",
    "origins": [ "http://localhost:8080" ],
    "timestampDriftTolerance": 300000,
    "MDSCacheDirPath": "/tmp/fido2-mds",
    "backupEligibleCredentialPolicy": "allowed",
    "backedUpCredentialPolicy": "allowed"
  },
  "Logging": {
    "IncludeScopes": false,
    "LogLevel": {
      "Default": "Warning"
    }
  }
}
