@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@functions {
    string isActive(string page) => Url.ActionContext.HttpContext.Request.Path == page ? "is-active" : "";
}
<!DOCTYPE html>
<html lang="en">

<head>
    <title>Passkeys, FIDO2 &amp; WebAuthn for .NET</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">


    <link href="https://fonts.googleapis.com/css?family=Work+Sans" rel="stylesheet">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/sweetalert2"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.11.0/umd/popper.min.js"
        integrity="sha384-b/U6ypiBEHpOf/4+1nzFpr53nxSS+GLCkfwBdFNTxtclqqenISfwAzpKaMNFNmj4"
        crossorigin="anonymous"></script>
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/limonte-sweetalert2/6.10.1/sweetalert2.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bulma/0.7.4/css/bulma.min.css" rel="stylesheet"
        type="text/css" />
    <script defer src="https://use.fontawesome.com/releases/v5.3.1/js/all.js"></script>
    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Work Sans', sans-serif;
        }

        .hero {
            background-color: #1e293b;
            background-image: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        }

        .footer {
            background-color: #f8fafc;
            border-top: 1px solid #e2e8f0;
        }

        .footer .myid-logo {
            max-width: 180px;
            height: auto;
            margin-bottom: 0.75rem;
        }

        .hero-body .hero-content {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .hero-body .hero-logo {
            max-width: 140px;
            height: auto;
            flex-shrink: 0;
        }

        .hero-body .hero-text {
            text-align: left;
        }
    </style>
    <!--<link href="/stylesheets/styles.css" rel="stylesheet" type="text/css" />-->
    <script src="~/js/helpers.js"></script>
</head>

<body>
    <section class="hero is-black is-medium">

        <div class="hero-body">
            <div class="container">
                <div class="hero-content">
                    <img class="hero-logo" src="~/images/MyID_Logo.svg" alt="MyID" />
                    <div class="hero-text">
                        <p class="title">
                            Passkeys, FIDO2 & WebAuthn for .NET
                        </p>
                        <p class="subtitle">
                            Enabling simple, secure authentication and mfa using FIDO2 / WebAuthn
                        </p>
                    </div>
                </div>
            </div>
        </div>

        </section>
    @RenderBody()
    <footer class="footer" style="margin-top: 20vh">
        <div class="content has-text-centered">
            <p><strong>MyID</strong> &mdash; Passkeys, FIDO2 &amp; WebAuthn for .NET</p>
            <p><small>&copy; @DateTime.UtcNow.Year Intercede. All rights reserved.</small></p>
        </div>
    </footer>
    <script src="~/js/instant.js"></script>
</body>

</html>